#!/bin/bash

BAT="/sys/class/power_supply/BAT0"
NOTIF_ID=""

while true; do
    PERC=$(cat "$BAT/capacity")
    STATUS=$(cat "$BAT/status")

    if [[ "$STATUS" == "Charging" || "$PERC" -ge 20 ]]; then
        # Clear any existing notification
        if [[ -n "$NOTIF_ID" ]]; then
            dunstctl close "$NOTIF_ID"
            NOTIF_ID=""
        fi
    else
        # Battery below 20% and discharging
        if [[ -z "$NOTIF_ID" ]]; then
            NOTIF_ID=$(dunstify -u critical -r 9999 "Battery Low" "Battery is at ${PERC}%")
        fi
    fi

    sleep 20
done

sleep 10

updates=$(pacman -Qu)
if [ -n "$updates" ]; then     count=$(echo "$updates" | wc -l);     dunstify -u critical -r 9990 "pkgs ($count)" "\n$updates"; fi
