bindsym Mod1+minus scratchpad show

exec --no-startup-id xss-lock -l -- i3lock -n -k -f -p win -c 000000 &
exec --no-startup-id picom -b
exec --no-startup-id feh --bg-scale ~/lol/bg.png
exec --no-startup-id i3-msg "workspace 1; exec alacritty -e btop -t -u 100" && \
					 i3-msg "workspace 3; exec alacritty"

