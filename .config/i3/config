bindsym $mod+b bar mode toggle
bindsym $mod+c kill

#bindsym XF86AudioStop exec --no-startup-id systemctl reboot
bindsym XF86AudioStop exec "i3-nagbar -m 'Reboot the system now?' -b 'Reboot' 'systemctl reboot'
bindsym KP_Add exec playerctl play-pause

bindsym $mod+Return exec alacritty
bindsym $mod+w exec firefox
bindsym $mod+g exec firefox --new-window grok.com
bindsym $mod+Shift+w exec helium-browser
bindsym $mod+Shift+g exec helium-browser --new-window grok.com
bindsym $mod+d exec --no-startup-id rofi -show drun -show-icons -theme gruvbox-dark
bindsym $mod+Shift+d exec --no-startup-id i3-dmenu-desktop

bindsym $mod+Right focus right

bindsym $mod+KP_Enter exec --no-startup-id alacritty -e sh -c "systemctl start bluetoothctl" && alacritty -e sh -c "bluetoothctl"
bindsym Ctrl+slash exec --no-startup-id xinput set-prop "ELAN469D:00 04F3:304B Touchpad" "libinput Tapping Enabled" 1 && setxkbmap -option caps:escape_shifted_capslock

bindsym $mod+e exec caja
bindsym $mod+i exec --no-startup-id alacritty -e ~/.config/i3/wttr3
bindsym $mod+Shift+i exec --no-startup-id alacritty -e ~/.config/i3/wttr2
bindsym $mod+o exec --no-startup-id exec alacritty -e sh -c "curl wttr.in/Rijswijk?2 && read -n 1"

bindsym $mod+semicolon fullscreen toggle
bindsym $mod+z floating toggle

bindsym $mod+a focus left
bindsym $mod+k focus right

bindsym $mod+Tab workspace back_and_forth
bindsym $mod+x exec --no-startup-id xcolor >> lol.txt

#### AUDIO ####

# pact list short sinks

bindsym Ctrl+Shift+k exec --no-startup-id pactl set-source-mute alsa_input.pci-0000_00_1f.3.analog-stereo
bindsym Ctrl+Shift+l exec --no-startup-id pactl set-source-mute v4l2_input.pci-0000_00_14.0-usb-0_7_1.0 1

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym KP_Subtract exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

bindsym XF86AudioNext exec --no-startup-id pactl set-card-profile alsa_card.pci-0000_00_1f.3 output:hdmi-stereo+input:analog-stereo
bindsym XF86AudioPrev exec --no-startup-id pactl set-card-profile alsa_card.pci-0000_00_1f.3 output:analog-stereo+input:analog-stereo

bindsym Shift+XF86AudioNext exec --no-startup-id pactl pactl set-default-sink alsa_output.pci-0000_00_1f.3.analog-stereo
bindsym Shift+XF86AudioPrev exec --no-startup-id pactl set-card-profile alsa_output.usb-Sony_Interactive_Entertainment_Wireless_Controller-00.analog-stereo

#### MONITOR ####

exec_always --no-startup-id redshift -P -O 4000

bindsym $mod+n exec --no-startup-id feh --bg-scale ~/lol/bg.png
bindsym $mod+h exec --no-startup-id pkill feh & xsetroot -solid "#0c0c0c"

bindsym $mod+u exec --no-startup-id xcalc -bg black -fg grey -bd grey
#bindsym $mod+Shift+u exec --no-startup-id xcalc -bg black -fg grey -bd grey
bindsym $mod+y exec firefox --new-window https://www.youtube.com/playlist?list=LL
#bindsym $mod+y exec --no-startup-id pkill picom
#bindsym $mod+u exec --no-startup-id picom &

bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set 15%+
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 15%-

bindsym Ctrl+Shift+y exec --no-startup-id xset s on +dpms
bindsym Ctrl+Shift+g exec --no-startup-id xset s off -dpms

bindsym $mod+KP_Add exec --no-startup-id i3lock -f -p win -c 000000 -i ~/lol/bg.png
bindsym $mod+space exec --no-startup-id i3lock -f -p win -c 000000
bindsym XF86AudioPlay exec --no-startup-id i3lock -f -p win -c 000000 && systemctl suspend

bindsym $mod+p exec --no-startup-id xrandr --output eDP1 --off
bindsym $mod+l exec --no-startup-id xrandr --output eDP1 --mode 1920x1080

bindsym $mod+m layout default
bindsym $mod+f layout toggle tabbed split

#### MOUSE ####

bindsym --whole-window button9 kill
bindsym --whole-window button8 exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status

#### DEFAULT ####

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

mode "resize" {

        bindsym Right       resize shrink width 10 px or 10 ppt
        bindsym Down        resize grow height 10 px or 10 ppt
        bindsym Up          resize shrink height 10 px or 10 ppt
        bindsym Left        resize grow width 10 px or 10 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym Mod1+r mode "default"
}

bindsym Mod1+r mode "resize"


